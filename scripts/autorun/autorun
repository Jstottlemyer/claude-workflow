#!/bin/bash
##############################################################################
# scripts/autorun/autorun
#
# Thin CLI wrapper around run.sh.
# Usage: autorun <start|stop|status>
#
#   start   — run the queue (blocks until complete)
#   stop    — write STOP file (halts after current build wave)
#   status  — show current stage and recent run log
##############################################################################
set -euo pipefail

# Resolve real script location — handles symlinks (macOS-compatible, no readlink -f)
_self="$0"
while [ -L "$_self" ]; do
    _dir="$(cd "$(dirname "$_self")" && pwd)"
    _target="$(readlink "$_self")"
    case "$_target" in /*) _self="$_target" ;; *) _self="$_dir/$_target" ;; esac
done
ENGINE_DIR="$(cd "$(dirname "$_self")/../.." && pwd)"
unset _self _dir _target

# PROJECT_DIR = the target repo to operate on (override via AUTORUN_PROJECT_DIR)
PROJECT_DIR="${AUTORUN_PROJECT_DIR:-$PWD}"
QUEUE_DIR="$PROJECT_DIR/queue"
export ENGINE_DIR PROJECT_DIR

case "${1:-}" in
    start)
        # v6: locking moved into run.sh via _policy.sh (slug-scoped lockfile under
        # queue/runs/.locks/<slug>.lock). Wrapper no longer calls flock — see
        # spec AC#23 + plan Task 3.0.

        # One-time deprecation: remove legacy queue-wide lock if present.
        if [ -e "$QUEUE_DIR/.autorun.lock" ]; then
            echo "[autorun] removing legacy queue/.autorun.lock (slug-scoped locking moved to run.sh)" >&2
            rm -f "$QUEUE_DIR/.autorun.lock"
        fi

        # Forward all remaining args to run.sh; exec for a clean process table.
        shift
        exec bash "$ENGINE_DIR/scripts/autorun/run.sh" "$@"
        ;;

    stop)
        touch "$QUEUE_DIR/STOP"
        echo "autorun: STOP file written. Run will halt after the current build wave completes."
        echo "Remove queue/STOP before the next run."
        ;;

    status)
        echo "=== autorun status ==="
        echo ""
        echo "Current stage:"
        if [ -f "$QUEUE_DIR/.current-stage" ]; then
            cat "$QUEUE_DIR/.current-stage"
        else
            echo "  (not running)"
        fi
        echo ""
        echo "STOP file: $([ -f "$QUEUE_DIR/STOP" ] && echo 'present (will halt after current wave)' || echo 'not set')"
        echo ""
        echo "Recent run log (last 5 lines):"
        if [ -f "$QUEUE_DIR/run.log" ]; then
            tail -5 "$QUEUE_DIR/run.log"
        else
            echo "  (no run.log yet)"
        fi
        echo ""
        echo "Queue:"
        ls "$QUEUE_DIR"/*.spec.md 2>/dev/null | while read -r f; do
            slug="$(basename "$f" .spec.md)"
            if [ -f "$QUEUE_DIR/$slug/run-summary.md" ]; then
                echo "  $slug: complete"
            elif [ -f "$QUEUE_DIR/$slug/failure.md" ]; then
                echo "  $slug: FAILED"
            elif [ -f "$QUEUE_DIR/$slug/state.json" ]; then
                stage="$(python3 -c "import json; print(json.load(open('$QUEUE_DIR/$slug/state.json')).get('stage','?'))" 2>/dev/null || echo '?')"
                echo "  $slug: in-progress (stage=$stage)"
            else
                echo "  $slug: pending"
            fi
        done
        ;;

    *)
        echo "Usage: autorun <start|stop|status>"
        echo ""
        echo "  start   — run the queue (blocks until complete)"
        echo "  stop    — write STOP file (halts after current build wave)"
        echo "  status  — show current stage and recent run log"
        exit 1
        ;;
esac
